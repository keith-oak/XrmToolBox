<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:XrmToolBox.MacOS.ViewModels"
        xmlns:plg="using:XrmToolBox.MacOS.Plugins"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="XrmToolBox.MacOS.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="XrmToolBox for macOS"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600">

  <Grid RowDefinitions="Auto,*,Auto">

    <Border Grid.Row="0" Background="{DynamicResource SystemAltMediumColor}" Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Dataverse URL:" VerticalAlignment="Center" />
        <TextBox Text="{Binding DataverseUrl}" Width="380" />
        <Button Content="Connect" Command="{Binding ConnectCommand}" />
        <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource SystemAccentColor}" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280,*">

      <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Available tools" FontWeight="SemiBold" Padding="12,8" />
          <ListBox ItemsSource="{Binding AvailablePlugins}"
                   DoubleTapped="OnPluginDoubleTapped">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="plg:PluginEntry">
                <StackPanel Margin="4">
                  <TextBlock Text="{Binding Metadata.Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Metadata.Description}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <TabControl Grid.Column="1"
                  ItemsSource="{Binding OpenedPlugins}"
                  SelectedItem="{Binding ActivePlugin}">
        <TabControl.ItemTemplate>
          <DataTemplate DataType="vm:OpenedPluginViewModel">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Title}" />
              <Button Content="✕" Padding="4,0" FontSize="10"
                      Command="{Binding $parent[TabControl].((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                      CommandParameter="{Binding}" />
            </StackPanel>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate DataType="vm:OpenedPluginViewModel">
            <ContentControl Content="{Binding View}" />
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>

    </Grid>

    <Border Grid.Row="2" Background="{DynamicResource SystemAltMediumColor}" Padding="12,4">
      <TextBlock Text="XrmToolBox for macOS — native Avalonia build" FontSize="11" />
    </Border>

  </Grid>

</Window>
