<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:XrmToolBox.MacOS.ViewModels"
        xmlns:plg="using:XrmToolBox.MacOS.Plugins"
        xmlns:set="using:XrmToolBox.MacOS.Settings"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="XrmToolBox.MacOS.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PAC'd Toolbox"
        Width="1180" Height="760"
        MinWidth="980" MinHeight="640"
        Background="{DynamicResource WindowBackgroundBrush}"
        TransparencyLevelHint="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="PreferSystemChrome">

  <Window.KeyBindings>
    <KeyBinding Gesture="Meta+K" Command="{Binding ToggleCommandPaletteCommand}" />
    <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleCommandPaletteCommand}" />
    <KeyBinding Gesture="Meta+OemComma" Command="{Binding ToggleSettingsCommand}" />
    <KeyBinding Gesture="Ctrl+OemComma" Command="{Binding ToggleSettingsCommand}" />
    <KeyBinding Gesture="Meta+R" Command="{Binding ReloadPluginsCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadPluginsCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding CloseAllOverlaysCommand}" />
  </Window.KeyBindings>

  <Grid>

    <!-- Main shell -->
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Toolbar -->
      <Border Grid.Row="0" Classes="toolbar" Padding="80,8,12,8">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
          <TextBlock Grid.Column="0" Text="Dataverse" Classes="footnote secondary" VerticalAlignment="Center" Margin="0,0,8,0" />
          <AutoCompleteBox Grid.Column="1"
                           Width="380"
                           Text="{Binding DataverseUrl}"
                           ItemsSource="{Binding RecentConnections}"
                           ValueMemberBinding="{Binding Url}"
                           FilterMode="Contains">
            <AutoCompleteBox.ItemTemplate>
              <DataTemplate DataType="set:RecentConnection">
                <StackPanel>
                  <TextBlock Text="{Binding OrganizationFriendlyName}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Url}" Classes="footnote secondary" />
                </StackPanel>
              </DataTemplate>
            </AutoCompleteBox.ItemTemplate>
          </AutoCompleteBox>
          <Button Grid.Column="2"
                  Margin="8,0,0,0"
                  Content="{Binding ConnectButtonCaption}"
                  Command="{Binding ConnectCommand}"
                  Classes="primary"
                  Classes.connected="{Binding IsConnected}" />
          <Ellipse Grid.Column="3" Width="8" Height="8" VerticalAlignment="Center" Margin="8,0,0,0"
                   IsVisible="{Binding IsConnected}"
                   Fill="{DynamicResource SuccessBrush}" />
          <TextBlock Grid.Column="4" Text="{Binding ConnectionStatus}" Classes="footnote" VerticalAlignment="Center" Margin="6,0,0,0" />
          <Button Grid.Column="6"
                  Content="Browse Tools"
                  Classes="tertiary"
                  Command="{Binding ToggleStoreCommand}" />
        </Grid>
      </Border>

      <!-- Body: branded sidebar + section content -->
      <Grid Grid.Row="1" ColumnDefinitions="240,1,*">

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Classes="sidebar" BorderThickness="0">
          <DockPanel>

            <!-- Brand chip -->
            <Border DockPanel.Dock="Top" Padding="14,14,14,16">
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Width="32" Height="32" CornerRadius="8"
                        Background="{DynamicResource AccentBrush}"
                        VerticalAlignment="Center">
                  <TextBlock Text="&gt;_" FontWeight="Bold" FontSize="14"
                             Foreground="{DynamicResource AccentForegroundBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="PAC'd Toolbox" FontWeight="SemiBold" FontSize="14" />
                  <TextBlock Text="Power Platform" Classes="footnote secondary" />
                </StackPanel>
              </StackPanel>
            </Border>

            <ListBox Classes="sidebar"
                     ItemsSource="{Binding NavItems}"
                     SelectedItem="{Binding SelectedNav}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:NavItem">
                  <Grid ColumnDefinitions="22,*" Height="28">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Icon}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Label}"
                               FontWeight="Medium"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

          </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource HairlineBrush}" Width="1" />

        <!-- CONTENT AREA — switches based on SelectedNav -->
        <Grid Grid.Column="2">

          <!-- HOME -->
          <ScrollViewer IsVisible="{Binding IsHomeActive}">
            <StackPanel Margin="32,28,32,28" Spacing="{DynamicResource SpacingXl}">

              <StackPanel Spacing="{DynamicResource SpacingXs}">
                <TextBlock Classes="large-title" Text="Welcome back" />
                <TextBlock Classes="footnote secondary" Text="Your Power Platform productivity hub." />
              </StackPanel>

              <!-- Quick Actions -->
              <StackPanel Spacing="{DynamicResource SpacingSm}">
                <TextBlock Classes="title-2" Text="Quick Actions" />
                <UniformGrid Columns="2" Rows="2">
                  <Border Classes="card quick-action" Margin="0,0,8,8">
                    <Button Classes="quick-action-target"
                            Command="{Binding QuickOpenPowerPlatformCommand}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="↗" FontSize="22" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Open Power Platform" FontWeight="SemiBold" />
                        <TextBlock Text="Open a URL to your Power Platform Environment" Classes="footnote secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Button>
                  </Border>
                  <Border Classes="card quick-action" Margin="8,0,0,8">
                    <Button Classes="quick-action-target"
                            Command="{Binding QuickRunPacCommand}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="⌘" FontSize="22" Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Run PAC Command" FontWeight="SemiBold" />
                        <TextBlock Text="Run a custom PAC CLI command" Classes="footnote secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Button>
                  </Border>
                  <Border Classes="card quick-action" Margin="0,0,8,0">
                    <Button Classes="quick-action-target"
                            Command="{Binding QuickBrowseEnvironmentCommand}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="🌐" FontSize="20" />
                        <TextBlock Text="Browse Environment" FontWeight="SemiBold" />
                        <TextBlock Text="View environment details and metadata" Classes="footnote secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Button>
                  </Border>
                  <Border Classes="card quick-action" Margin="8,0,0,0">
                    <Button Classes="quick-action-target"
                            Command="{Binding QuickImportSolutionCommand}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="📦" FontSize="20" />
                        <TextBlock Text="Import Solution" FontWeight="SemiBold" />
                        <TextBlock Text="Import a managed or unmanaged solution" Classes="footnote secondary" TextWrapping="Wrap" />
                      </StackPanel>
                    </Button>
                  </Border>
                </UniformGrid>
              </StackPanel>

              <!-- Recent Tools -->
              <StackPanel Spacing="{DynamicResource SpacingSm}">
                <TextBlock Classes="title-2" Text="Recent Tools" />
                <Border Classes="card" Padding="0">
                  <ListBox ItemsSource="{Binding RecentTools}"
                           Background="Transparent"
                           BorderThickness="0">
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="vm:RecentTool">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,8">
                          <TextBlock Grid.Column="0" Text="🧩" FontSize="14" Margin="0,0,12,0" />
                          <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center" />
                          <Border Grid.Column="2" Padding="8,2" CornerRadius="10" Background="{DynamicResource AccentSoftBrush}" Margin="0,0,12,0">
                            <TextBlock Text="{Binding Badge}" Classes="caption" Foreground="{DynamicResource AccentBrush}" />
                          </Border>
                          <TextBlock Grid.Column="3" Text="{Binding Relative}" Classes="caption secondary" VerticalAlignment="Center" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Border>
                <TextBlock Classes="footnote secondary"
                           IsVisible="{Binding !RecentTools.Count}"
                           Text="Open a tool from the sidebar — it'll appear here." />
              </StackPanel>

            </StackPanel>
          </ScrollViewer>

          <!-- TOOLS -->
          <Grid IsVisible="{Binding IsToolsActive}" ColumnDefinitions="280,1,*">

            <Border Grid.Column="0" Background="Transparent">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Available tools"
                           Classes="footnote secondary"
                           Padding="20,16,16,4" />
                <ListBox Classes="sidebar"
                         ItemsSource="{Binding AvailablePlugins}"
                         SelectedItem="{Binding SelectedPlugin}">
                  <ListBox.ItemTemplate>
                    <DataTemplate DataType="plg:PluginEntry">
                      <StackPanel Spacing="{DynamicResource SpacingXs}">
                        <TextBlock Text="{Binding Metadata.Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Metadata.Description}"
                                   Classes="footnote"
                                   TextWrapping="Wrap"
                                   MaxLines="2" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource HairlineBrush}" Width="1" />

            <Grid Grid.Column="2">
              <!-- Empty state -->
              <Border IsVisible="{Binding !OpenedPlugins.Count}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <StackPanel Spacing="{DynamicResource SpacingMd}"
                            HorizontalAlignment="Center"
                            MaxWidth="460">
                  <TextBlock Classes="large-title secondary" Text="No tool open"
                             HorizontalAlignment="Center" />
                  <TextBlock Classes="body secondary"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Text="Choose a tool from the list, browse the community catalogue, or press ⌘K to search." />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="{DynamicResource SpacingSm}">
                    <Button Content="Browse Tool Library" Classes="primary" Command="{Binding ToggleStoreCommand}" />
                    <Button Content="Command Palette (⌘K)" Classes="tertiary" Command="{Binding ToggleCommandPaletteCommand}" />
                  </StackPanel>
                  <TextBlock Classes="footnote secondary"
                             TextAlignment="Center"
                             IsVisible="{Binding !IsConnected}"
                             Text="Tip: connect to a Dataverse environment first." />
                </StackPanel>
              </Border>

              <TabControl Classes="macos"
                          Margin="12,8,12,8"
                          IsVisible="{Binding OpenedPlugins.Count}"
                          ItemsSource="{Binding OpenedPlugins}"
                          SelectedItem="{Binding ActivePlugin}">
                <TabControl.ItemTemplate>
                  <DataTemplate DataType="vm:OpenedPluginViewModel">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Title}" />
                      <Button Content="✕"
                              Classes="tab-close"
                              Command="{Binding $parent[TabControl].((vm:MainWindowViewModel)DataContext).CloseTabCommand}"
                              CommandParameter="{Binding}" />
                    </StackPanel>
                  </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                  <DataTemplate DataType="vm:OpenedPluginViewModel">
                    <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                            BorderBrush="{DynamicResource HairlineBrush}"
                            BorderThickness="1"
                            CornerRadius="0,8,8,8">
                      <ContentControl Content="{Binding View}" />
                    </Border>
                  </DataTemplate>
                </TabControl.ContentTemplate>
              </TabControl>
            </Grid>

          </Grid>

          <!-- ENVIRONMENTS placeholder -->
          <StackPanel IsVisible="{Binding IsEnvironmentsActive}"
                      Margin="32,28,32,28"
                      Spacing="{DynamicResource SpacingMd}">
            <TextBlock Classes="large-title" Text="Environments" />
            <TextBlock Classes="footnote secondary"
                       Text="View, switch, and audit Power Platform environments. Coming soon — will list all environments your account can access." />
          </StackPanel>

          <!-- CONNECTIONS placeholder -->
          <StackPanel IsVisible="{Binding IsConnectionsActive}"
                      Margin="32,28,32,28"
                      Spacing="{DynamicResource SpacingMd}">
            <TextBlock Classes="large-title" Text="Connections" />
            <TextBlock Classes="footnote secondary"
                       Text="Manage saved connections. The toolbar URL field shows your most recent — full management UI lives here." />
            <ListBox ItemsSource="{Binding RecentConnections}"
                     Background="Transparent"
                     BorderThickness="0"
                     MaxHeight="500">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="set:RecentConnection">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,8">
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="{Binding OrganizationFriendlyName}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Url}" Classes="footnote secondary mono" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Forget" Classes="tertiary"
                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ForgetRecentCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>

          <!-- SETTINGS pane (inline) -->
          <ScrollViewer IsVisible="{Binding IsSettingsActive}">
            <StackPanel Margin="32,28,32,28" Spacing="{DynamicResource SpacingXl}">
              <StackPanel Spacing="{DynamicResource SpacingXs}">
                <TextBlock Classes="large-title" Text="Settings" />
                <TextBlock Classes="footnote secondary" Text="Configure your PAC'd Toolbox experience." />
              </StackPanel>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Appearance" />
                  <TextBlock Classes="footnote secondary" Text="Theme override (live)" />
                  <ComboBox Width="240" SelectedIndex="0">
                    <ComboBoxItem Content="Auto (follow system)" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Dark" />
                  </ComboBox>
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Connections" />
                  <TextBlock Classes="footnote secondary" Text="Recent connections — Forget removes one and clears its token cache entry on next sign-in." />
                  <ListBox ItemsSource="{Binding RecentConnections}" MaxHeight="200">
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="set:RecentConnection">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding OrganizationFriendlyName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Url}" Classes="footnote secondary" />
                          </StackPanel>
                          <Button Grid.Column="1" Content="Forget" Classes="tertiary"
                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ForgetRecentCommand}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Plugins" />
                  <Button Content="Reload plugins" Command="{Binding ReloadPluginsCommand}" HorizontalAlignment="Left" />
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Files" />
                  <TextBlock Classes="footnote secondary mono" Text="{Binding SettingsService.SettingsPath}" />
                  <TextBlock Classes="footnote secondary mono" Text="{Binding SettingsService.PluginsDirectory}" />
                  <TextBlock Classes="footnote secondary mono" Text="{Binding SettingsService.LogsDirectory}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <!-- ABOUT pane (inline) -->
          <ScrollViewer IsVisible="{Binding IsAboutActive}">
            <StackPanel Margin="32,28,32,28" Spacing="{DynamicResource SpacingXl}" MaxWidth="640">
              <StackPanel Spacing="{DynamicResource SpacingXs}">
                <TextBlock Classes="large-title" Text="About PAC'd Toolbox" />
                <TextBlock Classes="footnote secondary" Text="The modern toolkit for Power Platform developers." />
              </StackPanel>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingMd}">
                  <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="14"
                            Background="{DynamicResource AccentBrush}">
                      <TextBlock Text="&gt;_" FontWeight="Bold" FontSize="22"
                                 Foreground="{DynamicResource AccentForegroundBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="PAC'd Toolbox" FontWeight="SemiBold" FontSize="17" />
                      <TextBlock Text="Version 2.0.0" Classes="footnote secondary" />
                    </StackPanel>
                  </StackPanel>
                  <TextBlock Classes="body" TextWrapping="Wrap"
                             Text="Built natively for macOS with Avalonia and .NET 10. Connects to Microsoft Dataverse via the Power Platform Dataverse Client and MSAL with macOS Keychain-backed token storage." />
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Lineage" />
                  <TextBlock Classes="body" TextWrapping="Wrap"
                             Text="Built on the XrmToolBox lineage by Tanguy Touzard / MscrmTools." />
                  <TextBlock Classes="footnote secondary mono" Text="https://www.xrmtoolbox.com" />
                </StackPanel>
              </Border>

              <Border Classes="card">
                <StackPanel Spacing="{DynamicResource SpacingSm}">
                  <TextBlock Classes="title-2" Text="Brand essence" />
                  <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="⚡" FontSize="14" Margin="0,4,12,8" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                      <TextBlock Text="Powerful" FontWeight="SemiBold" />
                      <TextBlock Text="Built for productivity and advanced workflows." Classes="footnote secondary" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="✨" FontSize="14" Margin="0,4,12,8" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                      <TextBlock Text="Modern" FontWeight="SemiBold" />
                      <TextBlock Text="Clean, current and delightful across platforms." Classes="footnote secondary" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="🛡" FontSize="14" Margin="0,4,12,8" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                      <TextBlock Text="Reliable" FontWeight="SemiBold" />
                      <TextBlock Text="Trusted open-source toolkit for the community." Classes="footnote secondary" TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="🖥" FontSize="14" Margin="0,4,12,0" />
                    <StackPanel Grid.Row="3" Grid.Column="1">
                      <TextBlock Text="Cross-Platform" FontWeight="SemiBold" />
                      <TextBlock Text="Seamless experience on macOS and Windows." Classes="footnote secondary" TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

        </Grid>

      </Grid>

      <!-- Status bar -->
      <Border Grid.Row="2" Classes="statusbar">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0" Classes="caption mono" VerticalAlignment="Center">
            PAC'd Toolbox · v2.0.0
          </TextBlock>
          <Button Grid.Column="1" Classes="tertiary"
                  Padding="8,2" FontSize="10"
                  Content="Settings (⌘,)"
                  Command="{Binding ToggleSettingsCommand}" />
          <TextBlock Grid.Column="2" Classes="caption secondary mono" VerticalAlignment="Center" Margin="8,0,0,0"
                     Text="{Binding OpenedPlugins.Count, StringFormat='{}{0} tab(s) open'}" />
        </Grid>
      </Border>

    </Grid>

    <!-- Overlay backdrop (Tool Library + Command Palette only — Settings
         and About are inline content panes selected via the sidebar). -->
    <Border Background="#7F000000"
            IsHitTestVisible="True">
      <Border.IsVisible>
        <MultiBinding Converter="{x:Static BoolConverters.Or}">
          <Binding Path="IsStoreOpen" />
          <Binding Path="IsCommandPaletteOpen" />
        </MultiBinding>
      </Border.IsVisible>
    </Border>

    <!-- Plugin Store panel -->
    <Border IsVisible="{Binding IsStoreOpen}"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CornerRadiusCard}"
            ClipToBounds="True"
            Width="800" Height="560"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="20,16" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
              <TextBlock Classes="title-1" Text="Tool Library" />
              <TextBlock Classes="footnote secondary" Text="{Binding Store.Status}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Classes="tertiary" Command="{Binding Store.RefreshCommand}" />
            <Button Grid.Column="2" Content="Done" Classes="primary" Command="{Binding ToggleStoreCommand}" Margin="8,0,0,0" />
          </Grid>
        </Border>
        <Grid ColumnDefinitions="*,1,260">
          <ListBox Grid.Column="0"
                   ItemsSource="{Binding Store.Packages}"
                   SelectedItem="{Binding Store.Selected}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:StorePackage">
                <Grid ColumnDefinitions="*,Auto" Margin="4,6">
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Description}" Classes="footnote secondary" TextWrapping="Wrap" MaxLines="2" />
                    <TextBlock Text="{Binding Authors}" Classes="caption secondary" />
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding DownloadCountDisplay}" Classes="caption secondary" VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Border Grid.Column="1" Background="{DynamicResource HairlineBrush}" Width="1" />
          <Border Grid.Column="2" Padding="20,16" Background="{DynamicResource WindowBackgroundBrush}">
            <ScrollViewer>
              <StackPanel Spacing="{DynamicResource SpacingSm}">
                <TextBlock Classes="title-2" Text="{Binding Store.Selected.Name, FallbackValue='Select a plugin'}" />
                <TextBlock Classes="footnote secondary" Text="{Binding Store.Selected.Authors}" />
                <TextBlock Classes="body" TextWrapping="Wrap" Text="{Binding Store.Selected.Description, FallbackValue=''}" />
                <Border Margin="0,12,0,0" Padding="12" CornerRadius="{DynamicResource CornerRadiusControl}"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                        IsVisible="{Binding Store.Selected, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <StackPanel Spacing="{DynamicResource SpacingSm}">
                    <TextBlock Classes="footnote warning" FontWeight="SemiBold" Text="Needs porting" />
                    <TextBlock Classes="footnote" TextWrapping="Wrap"
                               Text="Existing community plugins are .NET Framework + WinForms and won't load in this native shell. The agentic plugin porter (spec 002) auto-converts them. Install will be enabled once that ships." />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>
      </DockPanel>
    </Border>

    <!-- Command palette -->
    <Border IsVisible="{Binding IsCommandPaletteOpen}"
            Background="{DynamicResource SurfaceBackgroundBrush}"
            BorderBrush="{DynamicResource HairlineBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CornerRadiusCard}"
            Width="560" MaxHeight="400"
            HorizontalAlignment="Center" VerticalAlignment="Top"
            Margin="0,120,0,0">
      <DockPanel>
        <TextBox DockPanel.Dock="Top" Watermark="Type a command or tool name…"
                 BorderThickness="0"
                 Padding="16,12"
                 FontSize="{DynamicResource FontSizeTitle2}"
                 x:Name="PaletteSearchBox" />
        <ListBox x:Name="PaletteList"
                 ItemsSource="{Binding AvailablePlugins}"
                 Padding="8,4"
                 SelectionChanged="OnPaletteItemSelected">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="plg:PluginEntry">
              <StackPanel>
                <TextBlock Text="{Binding Metadata.Name}" />
                <TextBlock Text="{Binding Metadata.Description}" Classes="footnote secondary" MaxLines="1" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

  </Grid>

</Window>
