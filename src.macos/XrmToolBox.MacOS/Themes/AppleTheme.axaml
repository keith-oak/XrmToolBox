<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ResourceDictionary.ThemeDictionaries>

    <!-- =========================================================
         LIGHT — PAC'd Toolbox brand palette on a clean neutral.
         Primary: #6C5CE7 (electric purple)
         Secondary accents: #0964E3 / #00CEC9 / #2ECC71
         Neutrals: #0B0F14 → #F7F9FB
         ========================================================= -->
    <ResourceDictionary x:Key="Light">
      <!-- Surfaces -->
      <Color x:Key="WindowBackgroundColor">#F7F9FB</Color>
      <Color x:Key="SidebarBackgroundColor">#FFFFFF</Color>
      <Color x:Key="SurfaceBackgroundColor">#FFFFFF</Color>
      <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
      <Color x:Key="ToolbarBackgroundColor">#F7F9FB</Color>
      <Color x:Key="StatusBarBackgroundColor">#EEF1F5</Color>
      <Color x:Key="DividerColor">#1F0B0F14</Color>
      <Color x:Key="HairlineColor">#E5E7EB</Color>

      <!-- Text -->
      <Color x:Key="PrimaryTextColor">#0B0F14</Color>
      <Color x:Key="SecondaryTextColor">#475569</Color>
      <Color x:Key="TertiaryTextColor">#94A3B8</Color>

      <!-- Brand accent (primary purple) -->
      <Color x:Key="AccentColor">#6C5CE7</Color>
      <Color x:Key="AccentForegroundColor">#FFFFFF</Color>
      <Color x:Key="AccentHoverColor">#5848D6</Color>
      <Color x:Key="AccentPressedColor">#4837C2</Color>
      <Color x:Key="AccentSoftColor">#EEEBFE</Color>

      <!-- Secondary brand colours -->
      <Color x:Key="BlueColor">#0964E3</Color>
      <Color x:Key="TealColor">#00CEC9</Color>
      <Color x:Key="GreenColor">#2ECC71</Color>

      <!-- Semantic -->
      <Color x:Key="SuccessColor">#22C55E</Color>
      <Color x:Key="WarningColor">#F59E0B</Color>
      <Color x:Key="DestructiveColor">#EF4444</Color>
      <Color x:Key="InfoColor">#3B82F6</Color>

      <!-- Overlays / states -->
      <Color x:Key="HoverOverlayColor">#0F0B0F14</Color>
      <Color x:Key="PressedOverlayColor">#1F0B0F14</Color>
      <Color x:Key="SelectionBackgroundColor">#6C5CE7</Color>
      <Color x:Key="SelectionForegroundColor">#FFFFFF</Color>

      <!-- Controls -->
      <Color x:Key="ControlBorderColor">#E5E7EB</Color>
      <Color x:Key="ControlBackgroundColor">#FFFFFF</Color>

      <!-- Brushes -->
      <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{DynamicResource WindowBackgroundColor}" />
      <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{DynamicResource SurfaceBackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}" />
      <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{DynamicResource ToolbarBackgroundColor}" />
      <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="{DynamicResource StatusBarBackgroundColor}" />
      <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
      <SolidColorBrush x:Key="HairlineBrush" Color="{DynamicResource HairlineColor}" />
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextColor}" />
      <SolidColorBrush x:Key="SecondaryTextBrush" Color="{DynamicResource SecondaryTextColor}" />
      <SolidColorBrush x:Key="TertiaryTextBrush" Color="{DynamicResource TertiaryTextColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
      <SolidColorBrush x:Key="AccentForegroundBrush" Color="{DynamicResource AccentForegroundColor}" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
      <SolidColorBrush x:Key="AccentPressedBrush" Color="{DynamicResource AccentPressedColor}" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
      <SolidColorBrush x:Key="BlueBrush" Color="{DynamicResource BlueColor}" />
      <SolidColorBrush x:Key="TealBrush" Color="{DynamicResource TealColor}" />
      <SolidColorBrush x:Key="GreenBrush" Color="{DynamicResource GreenColor}" />
      <SolidColorBrush x:Key="DestructiveBrush" Color="{DynamicResource DestructiveColor}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
      <SolidColorBrush x:Key="HoverOverlayBrush" Color="{DynamicResource HoverOverlayColor}" />
      <SolidColorBrush x:Key="PressedOverlayBrush" Color="{DynamicResource PressedOverlayColor}" />
      <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{DynamicResource SelectionBackgroundColor}" />
      <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{DynamicResource SelectionForegroundColor}" />
      <SolidColorBrush x:Key="ControlBorderBrush" Color="{DynamicResource ControlBorderColor}" />
      <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource ControlBackgroundColor}" />
    </ResourceDictionary>

    <!-- =========================================================
         DARK — brand on neutral 900s. Mirrors the macOS mockup.
         ========================================================= -->
    <ResourceDictionary x:Key="Dark">
      <!-- Surfaces -->
      <Color x:Key="WindowBackgroundColor">#0B0F14</Color>
      <Color x:Key="SidebarBackgroundColor">#151A22</Color>
      <Color x:Key="SurfaceBackgroundColor">#1F2630</Color>
      <Color x:Key="SurfaceElevatedColor">#2A313C</Color>
      <Color x:Key="ToolbarBackgroundColor">#151A22</Color>
      <Color x:Key="StatusBarBackgroundColor">#0B0F14</Color>
      <Color x:Key="DividerColor">#33FFFFFF</Color>
      <Color x:Key="HairlineColor">#2A313C</Color>

      <!-- Text -->
      <Color x:Key="PrimaryTextColor">#F7F9FB</Color>
      <Color x:Key="SecondaryTextColor">#94A3B8</Color>
      <Color x:Key="TertiaryTextColor">#64748B</Color>

      <!-- Brand accent (electric purple, slightly brighter on dark) -->
      <Color x:Key="AccentColor">#7C6DF0</Color>
      <Color x:Key="AccentForegroundColor">#FFFFFF</Color>
      <Color x:Key="AccentHoverColor">#9485F4</Color>
      <Color x:Key="AccentPressedColor">#5848D6</Color>
      <Color x:Key="AccentSoftColor">#2A2545</Color>

      <Color x:Key="BlueColor">#3B82F6</Color>
      <Color x:Key="TealColor">#22D3D9</Color>
      <Color x:Key="GreenColor">#34D687</Color>

      <Color x:Key="SuccessColor">#22C55E</Color>
      <Color x:Key="WarningColor">#F59E0B</Color>
      <Color x:Key="DestructiveColor">#EF4444</Color>
      <Color x:Key="InfoColor">#3B82F6</Color>

      <Color x:Key="HoverOverlayColor">#1FFFFFFF</Color>
      <Color x:Key="PressedOverlayColor">#33FFFFFF</Color>
      <Color x:Key="SelectionBackgroundColor">#7C6DF0</Color>
      <Color x:Key="SelectionForegroundColor">#FFFFFF</Color>

      <Color x:Key="ControlBorderColor">#2A313C</Color>
      <Color x:Key="ControlBackgroundColor">#1F2630</Color>

      <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{DynamicResource WindowBackgroundColor}" />
      <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{DynamicResource SurfaceBackgroundColor}" />
      <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}" />
      <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{DynamicResource ToolbarBackgroundColor}" />
      <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="{DynamicResource StatusBarBackgroundColor}" />
      <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerColor}" />
      <SolidColorBrush x:Key="HairlineBrush" Color="{DynamicResource HairlineColor}" />
      <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextColor}" />
      <SolidColorBrush x:Key="SecondaryTextBrush" Color="{DynamicResource SecondaryTextColor}" />
      <SolidColorBrush x:Key="TertiaryTextBrush" Color="{DynamicResource TertiaryTextColor}" />
      <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
      <SolidColorBrush x:Key="AccentForegroundBrush" Color="{DynamicResource AccentForegroundColor}" />
      <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
      <SolidColorBrush x:Key="AccentPressedBrush" Color="{DynamicResource AccentPressedColor}" />
      <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
      <SolidColorBrush x:Key="BlueBrush" Color="{DynamicResource BlueColor}" />
      <SolidColorBrush x:Key="TealBrush" Color="{DynamicResource TealColor}" />
      <SolidColorBrush x:Key="GreenBrush" Color="{DynamicResource GreenColor}" />
      <SolidColorBrush x:Key="DestructiveBrush" Color="{DynamicResource DestructiveColor}" />
      <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
      <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />
      <SolidColorBrush x:Key="HoverOverlayBrush" Color="{DynamicResource HoverOverlayColor}" />
      <SolidColorBrush x:Key="PressedOverlayBrush" Color="{DynamicResource PressedOverlayColor}" />
      <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{DynamicResource SelectionBackgroundColor}" />
      <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{DynamicResource SelectionForegroundColor}" />
      <SolidColorBrush x:Key="ControlBorderBrush" Color="{DynamicResource ControlBorderColor}" />
      <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource ControlBackgroundColor}" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- Typography — Inter Tight is the brand body face, Inter for OS-level
       fallback. We ship Inter via Avalonia.Fonts.Inter and rely on the
       system font fallback for Inter Tight where the user has it installed;
       otherwise the chain falls back to system sans. -->
  <FontFamily x:Key="SystemFontFamily">Inter Tight,avares://Avalonia.Fonts.Inter/Assets#Inter,-apple-system,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif</FontFamily>

  <x:Double x:Key="FontSizeWindowTitle">17</x:Double>
  <x:Double x:Key="FontSizeLargeTitle">26</x:Double>
  <x:Double x:Key="FontSizeTitle1">20</x:Double>
  <x:Double x:Key="FontSizeTitle2">17</x:Double>
  <x:Double x:Key="FontSizeBody">13</x:Double>
  <x:Double x:Key="FontSizeCallout">12</x:Double>
  <x:Double x:Key="FontSizeFootnote">11</x:Double>
  <x:Double x:Key="FontSizeCaption">10</x:Double>

  <!-- Geometry -->
  <CornerRadius x:Key="CornerRadiusControl">8</CornerRadius>
  <CornerRadius x:Key="CornerRadiusCard">12</CornerRadius>
  <CornerRadius x:Key="CornerRadiusWindow">12</CornerRadius>
  <Thickness x:Key="ControlPadding">12,6</Thickness>
  <Thickness x:Key="CardPadding">16,14</Thickness>
  <Thickness x:Key="SidebarItemMargin">8,2</Thickness>
  <Thickness x:Key="SidebarItemPadding">12,8</Thickness>

  <!-- Spacing -->
  <x:Double x:Key="SpacingXs">4</x:Double>
  <x:Double x:Key="SpacingSm">8</x:Double>
  <x:Double x:Key="SpacingMd">12</x:Double>
  <x:Double x:Key="SpacingLg">16</x:Double>
  <x:Double x:Key="SpacingXl">24</x:Double>

</ResourceDictionary>
