<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===========================================================
       Default ListBox / ListBoxItem styling — brand purple selection
       across every list in the app, not just the sidebar.
       =========================================================== -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
    <Setter Property="Margin" Value="6,2" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
  </Style>

  <!-- Default selected state: subtle accent wash, keeps original text colours
       so secondary text / chips remain legible. The sidebar gets the strong
       purple-fill treatment via its own scoped selector below. -->
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
  </Style>

  <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <!-- macOS-style sidebar list -->
  <Style Selector="ListBox.sidebar">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,4" />
  </Style>

  <Style Selector="ListBox.sidebar ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="Padding" Value="{DynamicResource SidebarItemPadding}" />
    <Setter Property="Margin" Value="{DynamicResource SidebarItemMargin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="ListBox.sidebar ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
  </Style>

  <Style Selector="ListBox.sidebar ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
    <Setter Property="TextElement.Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
  </Style>

  <Style Selector="ListBox.sidebar ListBoxItem:selected:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
  </Style>

  <Style Selector="ListBox.sidebar ListBoxItem:selected TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
  </Style>

  <!-- Tab strip: macOS-style segmented tabs sitting on a hairline track -->
  <Style Selector="TabControl.macos">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <!-- The header panel area (where TabItems live) gets a hairline below
       and a tiny bit of padding so tabs float above it. -->
  <Style Selector="TabControl.macos /template/ ItemsPresenter#PART_ItemsPresenter">
    <Setter Property="Margin" Value="0,4,0,0" />
  </Style>

  <Style Selector="TabControl.macos > TabItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="8,8,0,0" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Margin" Value="0,0,2,0" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
  </Style>

  <!-- Hide Fluent's default coloured "pipe" inside the tab item. -->
  <Style Selector="TabControl.macos > TabItem /template/ Border#PART_SelectedPipe">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <!-- Hover: subtle wash. -->
  <Style Selector="TabControl.macos > TabItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
    <Setter Property="CornerRadius" Value="8,8,0,0" />
  </Style>

  <Style Selector="TabControl.macos > TabItem:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
  </Style>

  <!-- Selected: tab body becomes the surface colour, lifts above the
       content card with matching corner radius and border. -->
  <Style Selector="TabControl.macos > TabItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1,1,1,0" />
    <Setter Property="CornerRadius" Value="8,8,0,0" />
  </Style>

  <Style Selector="TabControl.macos > TabItem:selected">
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabControl.macos > TabItem:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
  </Style>

  <!-- Toolbar -->
  <Style Selector="Border.toolbar">
    <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <!-- Status bar -->
  <Style Selector="Border.statusbar">
    <Setter Property="Background" Value="{DynamicResource StatusBarBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="Padding" Value="12,3" />
    <Setter Property="Height" Value="22" />
  </Style>

  <!-- Sidebar surface -->
  <Style Selector="Border.sidebar">
    <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
  </Style>

  <!-- Card surface -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusCard}" />
    <Setter Property="Padding" Value="{DynamicResource CardPadding}" />
  </Style>

  <!-- Quick-action card on Home: subtle hover lift -->
  <Style Selector="Border.quick-action">
    <Setter Property="MinHeight" Value="108" />
  </Style>
  <Style Selector="Border.quick-action:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource SelectionForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusControl}" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    <Setter Property="FontFamily" Value="{DynamicResource SystemFontFamily}" />
  </Style>

  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <!-- AutoCompleteBox internal TextBox -->
  <Style Selector="AutoCompleteBox /template/ TextBox">
    <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource SelectionForegroundBrush}" />
  </Style>

  <!-- TextBlock global selection (Avalonia 11 supports SelectableTextBlock) -->
  <Style Selector="SelectableTextBlock">
    <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBackgroundBrush}" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource SelectionForegroundBrush}" />
  </Style>

</Styles>
