<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XrmToolBox.MacOS.App"
             RequestedThemeVariant="Default">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://XrmToolBox/Themes/AppleTheme.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://XrmToolBox/Styles/Buttons.axaml" />
    <StyleInclude Source="avares://XrmToolBox/Styles/TextBlocks.axaml" />
    <StyleInclude Source="avares://XrmToolBox/Styles/ListItems.axaml" />
  </Application.Styles>

</Application>
